{
  "name": "kagent",
  "icon": "icon.png",
  "displayName": "KAgent",
  "description": "将文件保存与 Agent 修改以股票 K 线图展示（一文件一股）",
  "version": "0.1.5",
  "publisher": "JStone",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JStone2934/KAgent.git"
  },
  "bugs": {
    "url": "https://github.com/JStone2934/KAgent/issues"
  },
  "homepage": "https://github.com/JStone2934/KAgent#readme",
  "keywords": [
    "cursor",
    "agent",
    "k-line",
    "visualization",
    "hooks"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kagent.openChart",
        "title": "KAgent: 打开行情图"
      },
      {
        "command": "kagent.installHooks",
        "title": "KAgent: 安装项目 Hooks"
      },
      {
        "command": "kagent.refresh",
        "title": "KAgent: 刷新行情",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kagent",
          "title": "KAgent",
          "icon": "$(graph-line)"
        }
      ]
    },
    "views": {
      "kagent": [
        {
          "type": "webview",
          "id": "kagent.marketView",
          "name": "全仓库行情"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "kagent.refresh",
          "when": "view == kagent.marketView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "KAgent",
      "properties": {
        "kagent.colorScheme": {
          "type": "string",
          "enum": [
            "cn",
            "us"
          ],
          "enumDescriptions": [
            "红涨绿跌（中国大陆 A 股）",
            "绿涨红跌（美股）"
          ],
          "default": "cn",
          "description": "行情图与列表的涨跌配色方案（A股/美股）"
        },
        "kagent.colorTone": {
          "type": "string",
          "enum": [
            "light",
            "dark"
          ],
          "enumDescriptions": [
            "亮色涨跌色号",
            "暗色涨跌色号（适合深色背景）"
          ],
          "default": "light",
          "description": "涨跌颜色的明暗风格，与 colorScheme 组合使用"
        },
        "kagent.capture.onSave": {
          "type": "boolean",
          "default": true,
          "description": "在每次保存（含自动保存）时记录一根 K 线"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "postinstall": "node -e \"require('fs').copyFileSync('node_modules/lightweight-charts/dist/lightweight-charts.standalone.production.js','media/lightweight-charts.js')\"",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "lightweight-charts": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.3"
  }
}
